<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Server_ui" style="flex-grow: 1; -unity-background-image-tint-color: rgb(255, 0, 218); background-color: rgba(255, 255, 255, 0); position: absolute;">
        <ui:Button text="Host" name="host" style="-unity-background-image-tint-color: rgb(255, 1, 1); background-color: rgb(0, 255, 223);"/>
        <ui:Button text="Server" name="server" style="background-color: rgb(255, 0, 240);"/>
        <ui:Button text="Client" name="client" style="background-color: rgb(255, 119, 0);"/>
        <ui:Button text="Disconnect" name="disconnect" style="background-color: rgb(143, 100, 255);"/>
        <ui:TextField label="IP Adress" placeholder-text="filler text" value="127.0.0.1" style="-unity-background-image-tint-color: rgb(255, 0, 0);"/>
    </ui:VisualElement>
</ui:UXML>
